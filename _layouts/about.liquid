---
layout: default
---
<style>
.about-full-width {
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  width: 100vw;
  box-sizing: border-box;
  max-width: none;
}
.hero-section {
  position: relative;
  width: 100%;
  margin-left: 0;
  min-height: 80vh;
  background-image: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)), url('{{ '/assets/img/gallery/lab-equipment-1.jpg' | relative_url }}');
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: white;
  overflow: hidden;
}
.hero-content {
  max-width: 900px;
  padding: 0 2rem;
}
.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
.scroll-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
.about-nav-grid {
  margin-top: 3rem;
  position: relative;
  z-index: 10;
  padding: 0 2rem;
}
.about-nav-grid .nav-card {
  border: none;2px;
  overflow: hidden;
  transition: transform 0.35s ease, box-shadow 0.35s ease;
  width: 100%;
  aspect-ratio: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
}
.about-nav-grid .nav-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 18px 48px rgba(0,0,0,0.16);
}
.about-nav-grid .nav-card-img {
  grid-column: 1 / 2;
  grid-row: 1 / 3;
  overflow: hidden;
  height: 100%;
}
.about-nav-grid .nav-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.about-nav-grid .nav-card-body {
  grid-column: 2 / 3;
  grid-row: 1 / 3;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: #ffffff
  flex-direction: column;
}
.about-nav-grid .nav-card-title {
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 0.85rem;
}
.
.about-nav-grid .nav-card .btn {
  align-self: flex-start;
  margin-top: auto;
}about-nav-grid .nav-card-text {
  font-size: 0.95rem;
  line-height: 1.5;
  margin-bottom: 1.2rem;
  flex-grow: 1;
}
.about-content {
  margin-top: 4rem;
}
</style>

<!-- Hero Section -->
<div class="about-full-width">
  <div class="hero-section scroll-reveal">
    <div class="hero-content">
      <h1 style="font-size: 4.5rem; font-weight: 700; margin-bottom: 1rem; text-shadow: 2px 2px 6px rgba(0,0,0,0.75);">DSSI Lab</h1>
      <p style="font-size: 1.7rem; margin-bottom: 2rem; text-shadow: 1px 1px 3px rgba(0,0,0,0.6);">Data Science and System Informatics Lab</p>
      <p style="font-size: 1.25rem; text-shadow: 1px 1px 3px rgba(0,0,0,0.6);">University of Georgia • College of Engineering</p>
    </div>
  </div>

  </div>

  <!-- Content Section -->
  <div class="container mt-5 about-content scroll-reveal">
    <div class="post">
      <article>
        <div class="clearfix">{{ content }}</div>

        {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
          {% include newsletter.liquid center=true %}
        {% endif %}
      </article>
    </div>
  </div>

  <!-- Navigation Cards Section -->
  <div class="container about-nav-grid">
    <div class="row justify-content-center">
      {% if page.navigation_cards %}
        {% for card in page.navigation_cards %}
          <div class="col-12 col-md-6 mb-4 d-flex justify-content-center">
            <div class="nav-card scroll-reveal">
              {% if card.image %}
                <div class="nav-card-img">
                  {% include figure.liquid path=card.image class="card-img-top" style="height: 100%; width: 100%; object-fit: cover;" %}
                </div>
              {% endif %}
              <div class="nav-card-body">
                <div class="nav-card-title">{{ card.title }}</div>
                <p class="nav-card-text">{{ card.description }}</p>
                <a href="{{ card.link | relative_url }}" class="btn btn-outline-primary" style="border-color: var(--global-theme-color); color: var(--global-theme-color); font-size: 0.95rem; padding: 0.65rem 1.25rem;">Learn More</a>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const reveals = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  reveals.forEach(el => observer.observe(el));
});
</script>