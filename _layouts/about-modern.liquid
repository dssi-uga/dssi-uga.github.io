---
layout: default
---
<!-- Hero Section -->
<section class="hero-section" style="background: linear-gradient(135deg, var(--global-theme-color) 0%, var(--global-hover-color) 100%); color: white; padding: 4rem 0; margin-bottom: 3rem;">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-8">
        <h1 class="display-4 font-weight-bold mb-3">{{ site.title }}</h1>
        <p class="lead mb-4">{{ page.subtitle }}</p>
        <p class="mb-4">{{ site.description }}</p>
        <a href="#about" class="btn btn-light btn-lg mr-3">Learn More</a>
        <a href="{{ '/projects/' | relative_url }}" class="btn btn-outline-light btn-lg">View Projects</a>
      </div>
      <div class="col-lg-4 text-center">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          <img src="{{ profile_image_path | relative_url }}" alt="Dr. Hongyue Sun" class="img-fluid rounded-circle shadow-lg" style="max-width: 250px; border: 4px solid white;">
        {% endif %}
      </div>
    </div>
  </div>
</section>

<div class="container">
  <!-- About Section -->
  <section id="about" class="mb-5">
    <div class="row">
      <div class="col-lg-8">
        <h2 class="mb-4">About the Lab</h2>
        <div class="content-section">
          {{ content }}
        </div>
      </div>
      <div class="col-lg-4">
        {% if page.profile.more_info %}
          <div class="card shadow-sm">
            <div class="card-body">
              <h5 class="card-title">Contact Information</h5>
              {{ page.profile.more_info }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </section>

  <!-- Research Areas -->
  <section class="research-areas mb-5">
    <h2 class="text-center mb-4">Research Focus Areas</h2>
    <div class="row">
      <div class="col-md-6 col-lg-3 mb-4">
        <div class="card h-100 shadow-sm border-0" style="border-left: 4px solid var(--global-theme-color);">
          <div class="card-body">
            <h5 class="card-title text-primary">Future Distributed Manufacturing</h5>
            <p class="card-text">Cyber-coordinated manufacturing architectures for real-time synchronization across distributed production systems.</p>
            <a href="{{ '/projects/future-distributed-manufacturing-systems/' | relative_url }}" class="btn btn-outline-primary btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3 mb-4">
        <div class="card h-100 shadow-sm border-0" style="border-left: 4px solid var(--global-hover-color);">
          <div class="card-body">
            <h5 class="card-title text-primary">Digital Twins</h5>
            <p class="card-text">High-fidelity digital twins for monitoring, simulation, validation, and optimization of manufacturing processes.</p>
            <a href="{{ '/projects/digital-twins-cyber-physical-testbeds/' | relative_url }}" class="btn btn-outline-primary btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3 mb-4">
        <div class="card h-100 shadow-sm border-0" style="border-left: 4px solid var(--global-highlight-color);">
          <div class="card-body">
            <h5 class="card-title text-primary">AI-Enabled Manufacturing</h5>
            <p class="card-text">Machine learning and IoT technologies for predictive modeling, fault detection, and adaptive process control.</p>
            <a href="{{ '/projects/ai-enabled-smart-manufacturing/' | relative_url }}" class="btn btn-outline-primary btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3 mb-4">
        <div class="card h-100 shadow-sm border-0" style="border-left: 4px solid var(--global-theme-color);">
          <div class="card-body">
            <h5 class="card-title text-primary">Sustainable Manufacturing</h5>
            <p class="card-text">Next-generation additive manufacturing and sustainable production workflows with process monitoring and quality assurance.</p>
            <a href="{{ '/projects/additive-and-sustainable-manufacturing/' | relative_url }}" class="btn btn-outline-primary btn-sm">Learn More</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- News and Publications -->
  <div class="row">
    <!-- Latest News -->
    {% if page.announcements and page.announcements.enabled %}
    <div class="col-lg-6 mb-5">
      <h3><a href="{{ '/news/' | relative_url }}" style="color: inherit;">Latest News</a></h3>
      {% include news.liquid limit=true %}
    </div>
    {% endif %}

    <!-- Selected Publications -->
    {% if page.selected_papers %}
    <div class="col-lg-6 mb-5">
      <h3><a href="{{ '/publications/' | relative_url }}" style="color: inherit;">Selected Publications</a></h3>
      {% include selected_papers.liquid %}
    </div>
    {% endif %}
  </div>

  <!-- Social Links -->
  {% if page.social %}
  <section class="text-center mb-5">
    <h3>Connect With Us</h3>
    <div class="social-links">
      <div class="contact-icons">{% social_links %}</div>
      <div class="contact-note mt-3">{{ site.contact_note }}</div>
    </div>
  </section>
  {% endif %}

  {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
    {% include newsletter.liquid center=true %}
  {% endif %}
</div>