---
layout: page
---

<style>
.projects-scroll {
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  width: 100vw;
  max-width: none;
  box-sizing: border-box;
  padding: 0;
  overflow-x: hidden;
}

.project-section {
  width: 100%;
  padding: 4rem 2rem;
  margin: 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  min-height: auto;
}

.project-section:last-child {
  border-bottom: none;
}

.project-section:nth-child(even) {
  grid-template-columns: 1fr 1fr;
}

.project-section:nth-child(even) .project-content {
  order: 2;
}

.project-section:nth-child(even) .project-image {
  order: 1;
}

.project-section:nth-child(odd) .project-content {
  order: 1;
}

.project-section:nth-child(odd) .project-image {
  order: 2;
}

.project-content {
  padding: 2rem 0;
}

.project-title {
  font-size: 2.2rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
  color: #ffffff;
}

.project-description {
  font-size: 1rem;
  line-height: 1.7;
  color: #e0e0e0;
  margin-bottom: 1.5rem;
}

.project-content h2 {
  font-size: 1.4rem;
  font-weight: 700;
  margin-top: 1.5rem;
  margin-bottom: 0.75rem;
  color: #ffffff;
}

.project-content h3 {
  font-size: 1.1rem;
  font-weight: 600;
  margin-top: 1.2rem;
  margin-bottom: 0.5rem;
  color: #ffffff;
}

.project-content p {
  margin-bottom: 1rem;
  line-height: 1.6;
  color: #e0e0e0;
}

.project-content ul,
.project-content ol {
  margin: 1rem 0 1rem 2rem;
  padding: 0;
}

.project-content li {
  margin-bottom: 0.5rem;
  line-height: 1.6;
}

.project-image {
  width: 100%;
  min-height: 300px;
  background: var(--global-bg-color);
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--global-text-color);
  font-size: 0.9rem;
  text-align: center;
  padding: 2rem;
}

.project-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.scroll-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

@media (max-width: 768px) {
  .project-section {
    grid-template-columns: 1fr;
    padding: 2rem 1rem;
    gap: 2rem;
  }

  .project-section:nth-child(even) {
    grid-template-columns: 1fr;
  }

  .project-section:nth-child(even) .project-content {
    order: 1;
  }

  .project-section:nth-child(even) .project-image {
    order: 2;
  }

  .project-title {
    font-size: 1.7rem;
  }

  .project-content h2 {
    font-size: 1.2rem;
  }

  .project-image {
    min-height: 250px;
  }
}
</style>

<div class="projects-scroll">
  {% assign sorted_projects = site.projects | sort: "importance" %}
  {% for project in sorted_projects %}
    <div class="project-section scroll-reveal {% if forloop.index0 % 2 == 1 %}reverse{% endif %}">
      <div class="project-content">
        <h1 class="project-title">{{ project.title }}</h1>
        {% if project.description %}
          <p class="project-description">{{ project.description }}</p>
        {% endif %}
        <div class="project-details">
          {{ project.content }}
        </div>
      </div>
      <div class="project-image">
        {% if project.img %}
          {% include figure.liquid loading="lazy" path=project.img class="img-fluid rounded" alt=project.title %}
        {% else %}
          <span>{{ project.title }} - Image coming soon</span>
        {% endif %}
      </div>
    </div>
  {% endfor %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const reveals = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  reveals.forEach(el => observer.observe(el));
});
</script>
