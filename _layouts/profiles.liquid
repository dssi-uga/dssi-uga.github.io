---
layout: page
---
<style>
.people-principal {
  margin-bottom: 3rem;
}
.principal-card {
  display: grid;
  grid-template-columns: minmax(320px, 44%) minmax(360px, 56%);
  gap: 2rem;
  align-items: center;
  padding: 2.5rem;
  background: #ffffff;
  border-radius: 24px;
  box-shadow: 0 18px 40px rgba(0,0,0,0.08);
  max-width: 1200px;
  margin: 0 auto;
}
.principal-image {
  width: 100%;
  min-width: 280px;
  max-width: 560px;
  overflow: hidden;
  border-radius: 24px;
  height: 100%;
}
.principal-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.principal-body {
  width: 100%;
  min-width: 280px;
}
.principal-title {
  margin-top: 0;
  margin-bottom: 1rem;
  font-size: 2.1rem;
  font-weight: 700;
}
.team-grid {
  margin-top: 2rem;
}
.team-card {
  border: none;
  border-radius: 20px;
  overflow: hidden;
  background: #ffffff;
  transition: transform 0.35s ease, box-shadow 0.35s ease;
}
.team-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 18px 40px rgba(0,0,0,0.1);
}
.team-card img {
  width: 100%;
  height: 220px;
  object-fit: cover;
}
.team-card-body {
  padding: 1.25rem;
}
.team-card-title {
  margin-bottom: 0.5rem;
  font-size: 1.1rem;
  font-weight: 700;
}
.team-card-meta {
  font-size: 0.95rem;
  line-height: 1.5;
}
.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
.scroll-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>
<div class="post">
  {% if page.principal %}
    <section class="people-principal scroll-reveal">
      <div class="principal-card">
        {% if page.principal.image %}
          <div class="principal-image">
            {% assign principal_image_path = page.principal.image | prepend: 'assets/img/' %}
            {% include figure.liquid loading="eager" path=principal_image_path class="img-fluid" style="width:100%; height:100%; object-fit:cover;" alt=page.principal.image %}
          </div>
        {% endif %}
        <div class="principal-body">
          {% if page.principal.more_info %}
            <div class="more-info">{{ page.principal.more_info }}</div>
          {% endif %}
          {% if page.principal.content %}
            {% capture principal_content %}{% include_relative {{ page.principal.content }} %}{% endcapture %}
            <div class="principal-details">{{ principal_content | markdownify }}</div>
          {% endif %}
        </div>
      </div>
    </section>
  {% endif %}

  <section class="team-grid">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
      {% if page.profiles %}
        {% for profile in page.profiles %}
          <div class="col">
            <div class="team-card scroll-reveal h-100">
              {% if profile.image %}
                <div>
                  {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
                  {% include figure.liquid loading="eager" path=profile_image_path class="card-img-top" style="height:100%; width:100%; object-fit:cover;" alt=profile.image %}
                </div>
              {% endif %}
              <div class="team-card-body">
                {% assign raw_name = profile.content | remove: 'profile_' | remove: '.md' | replace: '_', ' ' %}
                {% assign name_words = raw_name | split: ' ' %}
                {% capture profile_name %}{% for word in name_words %}{{ word | capitalize }}{% if forloop.last == false %} {% endif %}{% endfor %}{% endcapture %}
                <div class="team-card-title">{{ profile_name }}</div>
                <div class="team-card-meta">{{ profile.more_info }}</div>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </section>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const reveals = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));
});
</script>
