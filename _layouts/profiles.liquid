---
layout: page
---
<style>
.people-section {
  width: 100vw;
  margin-left: calc(-50vw + 50%);
  padding: 0 2rem;
  max-width: none;
}
.people-principal {
  margin-bottom: 5rem;
}
.principal-header {
  text-align: center;
  margin-bottom: 2.5rem;
}
.principal-header h2 {
  font-size: 2.2rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--global-text-color);
}
.principal-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  padding: 2.5rem;
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.06);
}
.principal-image {
  overflow: hidden;
  border-radius: 8px;
}
.principal-image img {
  width: 100%;
  height: auto;
  display: block;
}
.principal-body {
  padding: 0;
}
.principal-body h3 {
  font-size: 1.8rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  color: var(--global-text-color);
}
.principal-body .more-info p {
  margin-bottom: 0.5rem;
  font-size: 1rem;
  line-height: 1.6;
}
.principal-body .more-info strong {
  font-weight: 700;
}
.principal-body .principal-details {
  margin-top: 1.5rem;
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--global-text-color);
}
.team-section {
  margin-top: 5rem;
}
.team-header {
  text-align: center;
  margin-bottom: 3rem;
}
.team-header h2 {
  font-size: 2.2rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--global-text-color);
}
.team-header p {
  font-size: 1.1rem;
  color: var(--global-text-color);
  margin: 0;
}
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 2.5rem;
  margin-top: 2rem;
  width: 100%;
}
.team-card {
  border: none;
  border-radius: 8px;
  overflow: hidden;
  background: #000000;
  box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  transition: all 0.35s ease;
  display: flex;
  flex-direction: column;
  height: 100%;
}
.team-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 14px 32px rgba(0,0,0,0.12);
}
.team-card-img {
  width: 100%;
  height: 280px;
  overflow: hidden;
  background: var(--global-bg-color);
}
.team-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s ease;
}
.team-card:hover .team-card-img img {
  transform: scale(1.03);
}
.team-card-body {
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}
.team-card-title {
  margin-bottom: 0.5rem;
  font-size: 1.15rem;
  font-weight: 700;
  color: #ffffff;
}
.team-card-meta {
  font-size: 0.9rem;
  line-height: 1.6;
  color: #ffffff;
  margin-bottom: 1rem;
  border-bottom: 1px solid rgba(255,255,255,0.2);
  padding-bottom: 1rem;
}
.team-card-meta p {
  margin-bottom: 0.5rem;
}
.team-card-meta a {
  color: var(--global-theme-color);
  text-decoration: none;
  transition: opacity 0.25s ease;
}
.team-card-meta a:hover {
  opacity: 0.8;
  text-decoration: underline;
}
.team-card-bio {
  font-size: 0.85rem;
  line-height: 1.5;
  color: #e0e0e0;
  flex-grow: 1;
}
.team-card-bio p {
  margin: 0 0 0.75rem 0;
}
.team-card-bio p:last-child {
  margin-bottom: 0;
}
.team-card-bio ul {
  margin: 0.5rem 0 0 1.2rem;
  padding: 0;
}
.team-card-bio li {
  margin-bottom: 0.35rem;
}
.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
.scroll-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
@media (max-width: 768px) {
  .principal-card {
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
  }
  .principal-header h2,
  .team-header h2 {
    font-size: 1.7rem;
  }
  .team-grid {
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }
}
</style>
<div class="people-section">
  <div class="post">
    {% if page.principal %}
      <section class="people-principal scroll-reveal">
        <div class="principal-header">
          <h2>Principal Investigator</h2>
        </div>
        <div class="principal-card">
          {% if page.principal.image %}
            <div class="principal-image">
              {% assign principal_image_path = page.principal.image | prepend: 'assets/img/' %}
              {% include figure.liquid loading="eager" path=principal_image_path class="img-fluid" style="width:100%; height:auto; display:block;" alt=page.principal.image %}
            </div>
          {% endif %}
          <div class="principal-body">
            {% if page.principal.more_info %}
              <div class="more-info">{{ page.principal.more_info }}</div>
            {% endif %}
            {% if page.principal.content %}
              {% capture principal_content %}{% include_relative {{ page.principal.content }} %}{% endcapture %}
              <div class="principal-details">{{ principal_content | markdownify }}</div>
            {% endif %}
          </div>
        </div>
      </section>
    {% endif %}
  {% if profile.content %}
                  {% capture profile_bio %}{% include_relative {{ profile.content }} %}{% endcapture %}
                  <div class="team-card-bio">{{ profile_bio | markdownify }}</div>
                {% endif %}
              
    <section class="team-section">
      <div class="team-header">
        <h2>Meet the Team</h2>
        <p>Members of the DSSI Lab</p>
      </div>
      <div class="team-grid">
        {% if page.profiles %}
          {% for profile in page.profiles %}
            <div class="team-card scroll-reveal">
              {% if profile.image %}
                <div class="team-card-img">
                  {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
                  {% include figure.liquid loading="eager" path=profile_image_path class="card-img-top" style="height:100%; width:100%; object-fit:cover;" alt=profile.image %}
                </div>
              {% endif %}
              <div class="team-card-body">
                {% assign raw_name = profile.content | remove: 'profile_' | remove: '.md' | replace: '_', ' ' %}
                {% assign name_words = raw_name | split: ' ' %}
                {% capture profile_name %}{% for word in name_words %}{{ word | capitalize }}{% if forloop.last == false %} {% endif %}{% endfor %}{% endcapture %}
                <div class="team-card-title">{{ profile_name }}</div>
                <div class="team-card-meta">{{ profile.more_info }}</div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </section>
  </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const reveals = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));
});
</script>
